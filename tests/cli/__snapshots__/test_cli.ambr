# name: test_upcoming_help
  '''
                                                                                                      
   Usage: root upcoming [OPTIONS]                                                                     
                                                                                                      
   List the next pickups across all waste types in chronological order.                               
                                                                                                      
  ╭─ Options ────────────────────────────────────────────────────────────────────────────────────────╮
  │ *  --post-code             TEXT                  Postal code of the address                      │
  │                                                  [env var: TWENTEMILIEU_POST_CODE]               │
  │                                                  [required]                                      │
  │ *  --house-number          INTEGER               House number of the address                     │
  │                                                  [env var: TWENTEMILIEU_HOUSE_NUMBER]            │
  │                                                  [required]                                      │
  │    --house-letter          TEXT                  Optional house letter of the address            │
  │                                                  [env var: TWENTEMILIEU_HOUSE_LETTER]            │
  │    --limit         -n      INTEGER RANGE [x>=1]  Maximum number of upcoming pickups to show      │
  │                                                  [default: 5]                                    │
  │    --json                                        Emit machine-readable JSON output               │
  │    --help                                        Show this message and exit.                     │
  ╰──────────────────────────────────────────────────────────────────────────────────────────────────╯
  
  
  '''
# ---
